[Unit]
Description=Anime Monitor Telegram Bot
After=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/anime_monitor
ExecStart=/usr/bin/python3 /root/.openclaw/workspace/anime_monitor/bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
